# Database (PostgreSQL with pgvector via Supabase)
DATABASE_URL="postgresql://user:password@db.xxx.supabase.co:5432/postgres"

# Authentication (Supabase)
NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Redis (BullMQ) - Optional for Vercel, required for workers
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# AI Models
OLLAMA_BASE_URL="http://localhost:11434/api"
GOOGLE_AI_API_KEY="your-google-api-key"
OPENROUTER_API_KEY="your-openrouter-api-key"

# Storage (Cloudflare R2)
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_BUCKET_NAME="hydraskript-assets"
R2_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
R2_PUBLIC_DOMAIN="https://pub-<id>.r2.dev"

# Stripe (Payments)
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
